{
  "name": "@oc-health-sync/health-sync",
  "version": "0.1.1-next.6",
  "description": "Receives Apple HealthKit data from the oc-health-sync iOS app, stores it locally in SQLite, and provides agent tools for health data analysis.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": "Dominik Barcikowski",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dominikx96/oc-health-sync-plugin.git"
  },
  "homepage": "https://github.com/dominikx96/oc-health-sync-plugin#readme",
  "bugs": {
    "url": "https://github.com/dominikx96/oc-health-sync-plugin/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "healthkit",
    "apple-health",
    "health",
    "sqlite"
  ],
  "engines": {
    "node": ">=24"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0 <2027.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.3.0"
  }
}
